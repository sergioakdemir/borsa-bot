# Claude (Anthropic) API anahtari - AI yorumcu icin gerekli
ANTHROPIC_API_KEY=sk-ant-...

# Telegram sabah brifingi / uyari / portfoy bildirimleri
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# KAP / RSS (Mynet, BloombergHT, Investing) icin TR cikisli proxy (cografi engel asma)
KAP_PROXY_URL=

# TCMB EVDS makro verisi (USD/TRY, politika faizi, TUFE) - opsiyonel.
# Anahtar yoksa analiz zinciri makro veri olmadan calisir.
# https://evds2.tcmb.gov.tr adresinden uyelik ile alinir.
EVDS_API_KEY=
# EVDS once dogrudan, sonra bu proxy (yoksa KAP_PROXY_URL) ile denenir.
# Not: KAP proxy'si evds2.tcmb.gov.tr'ye HTTPS CONNECT'i engelliyor; EVDS host'una
# izin veren bir TR proxy gerekiyorsa burayi kullan.
# EVDS_PROXY_URL=

# Fed (ABD) politika faizi icin FRED API anahtari (ucretsiz) - opsiyonel.
# Yoksa sabit 5.25 kullanilir. https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Beklenti (sonraki karar) override'lari (opsiyonel, baz puan). Bos birakilirsa
# Fed icin Polymarket (ucretsiz), TCMB icin EVDS anketi denenir.
# FED_BEKLENTI_BP=-25
# TCMB_BEKLENTI_BP=0
# TCMB Piyasa Katilimcilari Anketi EVDS seri kodu (TP.BEK.S...); katalogdan teyit et.
# TCMB_BEKLENTI_EVDS_KOD=

# TUFE (yillik) icin investing.com ekonomik-takvim event URL'i (opsiyonel).
# TUFE EVDS'ten gelmezse buradan parse edilir. Turkiye CPI(YoY) event sayfasi
# (ulasilabilir oldugunda) tam URL'i verilir.
# TUFE_INVESTING_URL=https://tr.investing.com/economic-calendar/turkish-cpi-yoy-XXXX

# Hetzner Cloud haftalik snapshot (Cloud API token, Read & Write)
HETZNER_API_TOKEN=
# Opsiyonel: en yeni N snapshot disindakileri sil (varsayilan: silme yok)
# HETZNER_SNAPSHOT_KEEP=4

# Google Drive audit yedegi (opsiyonel) — servis hesabi JSON yolu/inline + klasor ID
GOOGLE_DRIVE_CREDENTIALS_JSON=/root/borsa-bot/config/gdrive-service-account.json
GOOGLE_DRIVE_FOLDER_ID=

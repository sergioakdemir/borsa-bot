# Claude (Anthropic) API anahtari - AI yorumcu icin gerekli
ANTHROPIC_API_KEY=sk-ant-...

# Telegram sabah brifingi / uyari / portfoy bildirimleri
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# KAP / RSS (Mynet, BloombergHT, Investing) icin TR cikisli proxy (cografi engel asma)
KAP_PROXY_URL=

# TCMB EVDS makro verisi (USD/TRY, politika faizi, TUFE) - opsiyonel.
# Anahtar yoksa analiz zinciri makro veri olmadan calisir.
# https://evds2.tcmb.gov.tr adresinden uyelik ile alinir.
EVDS_API_KEY=

# Hetzner Cloud haftalik snapshot (Cloud API token, Read & Write)
HETZNER_API_TOKEN=
# Opsiyonel: en yeni N snapshot disindakileri sil (varsayilan: silme yok)
# HETZNER_SNAPSHOT_KEEP=4
